{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@healer/shared": ["packages/shared/src/index.ts"],
      "@healer/content": ["packages/content/src/index.ts"],
      "@healer/persistence": ["packages/persistence/src/index.ts"]
    }
  }
}

